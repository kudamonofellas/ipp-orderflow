# Copy to .env and fill in. Never commit .env itself.
# VITE_DIRECTUS_URL = your Directus instance URL (prod or dev)
# VITE_DIRECTUS_TOKEN = a static Directus access token (create one in
#   Directus admin → User Directory → your user → Token). Use a read-only
#   role for the frontend until real auth lands.
VITE_DIRECTUS_URL=https://admin.kudafellas.cloud
VITE_DIRECTUS_TOKEN=your-directus-static-token-here